          "name": "Get Settings Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/settings"
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "_token", "value": "{{csrf_token}}", "type": "text" },
                { "key": "telegram_message_template", "value": "{{telegram_message_template}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/settings"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
