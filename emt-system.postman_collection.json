{
  "info": {
    "name": "EMT System - Full Route Collection",
    "description": "Postman collection generated from currently registered Laravel routes in routes/web.php.\n\nImportant notes:\n1) This project uses web/session auth + CSRF middleware (not token auth).\n2) Run 'Auth > 1. Get Login Page (CSRF)' first to capture csrf_token variable.\n3) Postman cookie jar will keep session cookies after login.\n4) After login, if CSRF mismatch happens on state-changing routes, refresh token by running a GET form page and updating csrf_token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "c4d0f2f7-0af4-4d72-9a03-emt-system-2026"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "pm.request.headers.upsert({ key: 'X-Requested-With', value: 'XMLHttpRequest' });",
          "const method = (pm.request.method || 'GET').toUpperCase();",
          "if (!['GET', 'HEAD', 'OPTIONS'].includes(method)) {",
          "  const csrf = pm.collectionVariables.get('csrf_token');",
          "  if (csrf) pm.request.headers.upsert({ key: 'X-CSRF-TOKEN', value: csrf });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Get Login Page (CSRF)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let token = null;",
                  "try {",
                  "  const body = pm.response.json();",
                  "  token = body && body.csrf_token ? body.csrf_token : null;",
                  "} catch (e) {",
                  "  const html = pm.response.text();",
                  "  const match = html.match(/name=\\\"_token\\\"\\s+value=\\\"([^\\\"]+)\\\"/);",
                  "  token = match && match[1] ? match[1] : null;",
                  "}",
                  "if (token) {",
                  "  pm.collectionVariables.set('csrf_token', token);",
                  "  console.log('csrf_token updated');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "2. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "_token", "value": "{{csrf_token}}", "type": "text" },
                { "key": "username", "value": "{{username}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "3. Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "_token", "value": "{{csrf_token}}", "type": "text" }
              ]
            },
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/"
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/patients?patient_name={{patient_name}}"
          }
        },
        {
          "name": "Show Patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/patients/{{patient_id}}"
          }
        }
      ]
    },
    {
      "name": "Medical Records",
